# ══════════════════════════════════════════════
#  ADÉCHAT — Variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs
# ══════════════════════════════════════════════

# ── Serveur ──
PORT=3000
# URL publique de VOTRE SITE (ex: Netlify) — utilisée pour les liens de retour après paiement
FRONTEND_URL=http://localhost:3000
# URL publique de CE SERVEUR (ex: Render, Railway) — utilisée pour le callback PayDunya.
# Si vide, on réutilise FRONTEND_URL (correct seulement si site et serveur sont au même endroit).
BACKEND_URL=

# ── WhatsApp Business Cloud API (Meta for Developers) ──
# Obtenez ces valeurs sur : https://developers.facebook.com
WA_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxx
WA_PHONE_NUMBER_ID=123456789012345
WA_VERIFY_TOKEN=adechat_mon_token_secret_2025

# ── Gemini AI (Google AI Studio) — utilisé en fallback si pas de clé Groq ──
# Obtenez votre clé gratuite sur : https://aistudio.google.com
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx

# ── Groq AI (gratuit, beaucoup plus rapide que Gemini) — PRIORITAIRE si renseigné ──
# Obtenez votre clé sur : https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ── Contexte boutique (utilisé par l'IA) ──
SHOP_CONTEXT="Je vends des pagnes wax et tissus africains. Prix entre 5 000 et 25 000 FCFA. Livraison disponible."

# ── Nom affiché sur la page de paiement PayDunya ──
SHOP_NAME="Ma Boutique"

# ── PayDunya (paiement Mobile Money / carte) ──
# Obtenez vos 4 clés sur : https://app.paydunya.com (Intégrer notre API → Voir les clés)
# IMPORTANT : il en faut 4, la clé publique seule ne suffit pas à créer une facture.
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
# "test" tant que vous n'avez pas activé le mode live sur PayDunya, sinon "live"
PAYDUNYA_MODE=test

# ── Firebase (optionnel — remplace le stockage en mémoire) ──
# FIREBASE_PROJECT_ID=adechat-xxxxx
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@adechat.iam.gserviceaccount.com

# ── Supabase (alternative à Firebase) ──
# SUPABASE_URL=https://xxxxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
